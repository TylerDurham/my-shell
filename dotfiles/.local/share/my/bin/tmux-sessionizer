#!/usr/bin/env bash

# #####################################
#
# ████████╗███╗   ███╗██╗   ██╗██╗  ██╗
# ╚══██╔══╝████╗ ████║██║   ██║╚██╗██╔╝
#    ██║   ██╔████╔██║██║   ██║ ╚███╔╝ 
#    ██║   ██║╚██╔╝██║██║   ██║ ██╔██╗ 
#    ██║   ██║ ╚═╝ ██║╚██████╔╝██╔╝ ██╗
#    ╚═╝   ╚═╝     ╚═╝ ╚═════╝ ╚═╝  ╚═╝
#
# #####################################

# https://github.com/ThePrimeagen/.dotfiles/blob/master/bin/.local/scripts/tmux-sessionizer

if [[ $# -eq 1 ]]; then
    selected="$1"
    if [[ ! -d "$selected" ]]; then
        echo "tmux-sessionizer: '$selected' is not a directory" >&2
        exit 1
    fi
else
    selected=$(find ~/Documents ~/Downloads ~/.ssh ~/Projects ~/.config -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf)
fi

if [[ -z "$selected" ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

# $TMUX can be stale after a compositor restart (socket gone but var still set)
tmux_socket="${TMUX%%,*}"
if [[ -n "$TMUX" ]] && [[ -S "$tmux_socket" ]]; then
    tmux switch-client -t "$selected_name"
else
    tmux attach-session -t "$selected_name"
fi
